# ─── Shared (kalshi/config.py) ──────────────────────────────────────────
# Kalshi API credentials. Used by every package that places trades.
# Get from https://kalshi.com/account/profile → API Keys → "Create new API key"
API_KEY_ID=
# Absolute path to the matching RSA private key .pem file
PRIVATE_KEY_PATH=

# ─── agent_trader ───────────────────────────────────────────────────────
# Anthropic API key. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
