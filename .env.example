# ─── Shared (kalshi/config.py) ──────────────────────────────────────────
# Kalshi API credentials. Used by every package that places trades.
# Get from https://kalshi.com/account/profile → API Keys → "Create new API key"
API_KEY_ID=
# Absolute path to the matching RSA private key .pem file
PRIVATE_KEY_PATH=

# ─── agent_trader ───────────────────────────────────────────────────────
# Anthropic API key. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Strategy parameters (strategy_config.py) ───────────────────────────
# These define your trading strategy. The repo ships with neutral defaults
# (50-99¢ band, 5% sizing) that don't reflect any specific researched edge.
#
# Use the tools in misprice_discovery/ to find the parameters that work for
# YOUR research, then set them here. Both nba_trading/ (the live bot) and
# misprice_discovery/ (the analysis scripts) read from these env vars.

# Lower bound of the favorite price band, in cents (0-100).
STRATEGY_PRICE_MIN=50

# Upper bound of the favorite price band, in cents (0-100).
STRATEGY_PRICE_MAX=99

# Fraction of available cash to risk per bet (0-1). Full Kelly is usually
# far above this — see misprice_discovery/kelly_simulator.py to calibrate.
# Conservative starting point: 0.05 (5%).
STRATEGY_BANKROLL_FRACTION=0.05

# Cents above the current ask we're willing to pay (slippage tolerance).
# 0 = only fill at the prevailing ask; 1-2 is typical for thin markets.
STRATEGY_LIMIT_BUFFER_CENTS=1

# Halt new bets if cash drops this far below its all-time peak (percent).
# Set higher than your expected max drawdown so it only fires on real breaks.
STRATEGY_MAX_DRAWDOWN_PCT=25

# Sport for the misprice_discovery scripts to default to. The live bot in
# nba_trading/ always trades NBA; this only affects analysis tools.
STRATEGY_SPORT=NBA

# ─── Bot state files (optional overrides) ───────────────────────────────
# Defaults are fine; override if you want them in a different location.
# SCHEDULE_FILE=schedule_data.json
# PORTFOLIO_FILE=portfolio_data.json
# HIGH_WATER_FILE=high_water_mark.json
